            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "src": [],
                  "description": "Select .wav or .mp3 file"
                },
                {
                  "key": "organization_id",
                  "value": "1",
                  "type": "text"
                },
                {
                  "key": "department_id",
                  "value": "1",
